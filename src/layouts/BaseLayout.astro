---
// Learn about using Astro layouts:
// https://docs.astro.build/en/core-concepts/layouts/

import Footer from '../components/Footer.astro';
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import DebugUserToggle from '../components/DebugUserToggle.astro';
import WaveBackground from '../components/WaveBackground.astro';
import config from '../config';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;

const toVars = (map: Record<string, string>) =>
	Object.entries(map).map(([k, v]) => `--${k}: ${v};`).join(' ');

const themeStyle = `
	:root { ${toVars(config.theme.light)} }
	:root.theme-dark { ${toVars(config.theme.dark)} }
`;
---

<html lang="en">
	<head>
		<MainHead title={title} description={description} />
		<base href="{import.meta.env.BASE_URL}" />
		<Fragment set:html={`<style>${themeStyle}</style>`} />
	</head>
	<body>
		<WaveBackground fallbackColor={config.theme.fallbackColor} />
		<div class="stack backgrounds">
			<Nav />
			<slot />
			<Footer />
		</div>
		<DebugUserToggle />

		<script>
			// Add “loaded” class once the document has completely loaded.
			addEventListener('load', () => document.documentElement.classList.add('loaded'));
		</script>

		<style>
			.backgrounds {
				position: relative;
				z-index: 1;
				min-height: 100%;
				isolation: isolate;
				background: transparent;
			}
		</style>
	</body>
</html>
