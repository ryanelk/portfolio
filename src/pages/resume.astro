---
import BaseLayout from '../layouts/BaseLayout.astro';

const resume = `${import.meta.env.BASE_URL}/assets/resume/ryanelkhoury_resume_2026.pdf`;
---

<BaseLayout title="Resume" description="About Ryan El Khoury Lorem Ipsum">
	<div class="stack gap-20">
		<div class="resume-container">
			<div class="download-section">
				<a href={resume} download="ryanelkhoury_resume_2026.pdf" class="download-btn">
					<svg class="download-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
					</svg>
					Download Resume
				</a>
			</div>

			<iframe
				src={resume}
				class="resume-embed"
				title="Resume"
				data-resume-src={resume}>
			</iframe>

			<div class="fallback-message" id="resume-fallback" style="display:none">
				<p>Unable to display PDF in your browser.</p>
				<a href={resume} class="fallback-link" target="_blank">Click here to view the resume</a>
			</div>
		</div>
	</div>

	<script>
		const iframe = document.querySelector<HTMLIFrameElement>('.resume-embed');
		iframe?.addEventListener('error', () => {
			iframe.style.display = 'none';
			const fallback = document.getElementById('resume-fallback');
			if (fallback) fallback.style.display = 'block';
		});
	</script>
</BaseLayout>

<style>
	.resume-container {
		max-width: 95vw;
		padding: 2rem;
	}

	.download-section {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.download-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		padding: 0.75rem 1.5rem;
		border: none;
		border-radius: 0.5rem;
		text-decoration: none;
		font-weight: 600;
		transition: background-color var(--theme-transition);
		cursor: pointer;
	}

	.download-btn:hover {
		background: var(--accent-dark);
	}

	.download-icon {
		width: 1.25rem;
		height: 1.25rem;
	}

	.resume-embed {
		width: 100%;
		height: 80vh;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		box-shadow: var(--shadow-md);
		overflow: hidden;
	}

	.fallback-message {
		text-align: center;
		padding: 2rem;
		color: var(--gray-400);
	}

	.fallback-link {
		color: var(--accent-regular);
		text-decoration: none;
	}

	.fallback-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		.resume-container {
			padding: 1rem;
		}

		.resume-embed {
			height: 90vh;
			overflow: hidden;
		}
	}
</style>
