---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import MusicStatus from './MusicStatus.astro';
import config from '../config/index';

const textLinks: { label: string; href: string }[] = [
	{ label: 'Home',     href: `${import.meta.env.BASE_URL}` },
	{ label: 'Projects', href: `${import.meta.env.BASE_URL}work/` },
	{ label: 'Resume',   href: `${import.meta.env.BASE_URL}resume/` },
	{ label: 'Contact',  href: `${import.meta.env.BASE_URL}contact/` },
];

const isCurrentPage = (href: string) => {
	let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
	if (pathname.at(0) !== '/') pathname = '/' + pathname;
	if (pathname.at(-1) !== '/') pathname += '/';
	return pathname === href || (href !== `${import.meta.env.BASE_URL}` && pathname.startsWith(href));
};
---

<nav>
	<noscript>
		<ul class="nav-items">
			{textLinks.map(({ label, href }) => (
				<li>
					<a aria-current={isCurrentPage(href) ? 'page' : null} class="link" href={href}>
						{label}
					</a>
				</li>
			))}
		</ul>
	</noscript>

	<!--
		Mobile-only bar: always visible.
		Contains the short name + hamburger button.
		Hidden on desktop via CSS.
	-->
	<div class="menu-header">
		<menu-button>
			<template>
				<button class="menu-button" aria-expanded="false" aria-label="Toggle menu">
					<span class="sr-only">Menu</span>
					<Icon icon="list" />
				</button>
			</template>
		</menu-button>
		<a href={`${import.meta.env.BASE_URL}`} class="site-title-mobile">REK</a>
	</div>

	<!--
		Collapsible on mobile (hidden until hamburger clicked).
		On desktop: display:contents → its 3 children fill the 3 grid columns:
		  col 1 = .nav-items (links pill, left)
		  col 2 = .site-title-desktop (full name, center)
		  col 3 = .nav-end (music + theme, right)
	-->
	<div id="menu-content" hidden>
		<ul class="nav-items">
			{textLinks.map(({ label, href }) => (
				<li>
					<a aria-current={isCurrentPage(href) ? 'page' : null} class="link" href={href}>
						{label}
					</a>
				</li>
			))}
		</ul>
		<a href={`${import.meta.env.BASE_URL}`} class="site-title-desktop" data-cfg="name">
			{config.name}
		</a>
		<div class="nav-end">
			<MusicStatus client:load />
			<ThemeToggle />
		</div>
	</div>
</nav>

<script>
	class MenuButton extends HTMLElement {
		constructor() {
			super();
			this.appendChild(this.querySelector('template')!.content.cloneNode(true));
			const btn = this.querySelector('button')!;
			const menu = document.getElementById('menu-content')!;

			menu.hidden = true;
			menu.classList.add('menu-content');

			const setExpanded = (expand: boolean) => {
				btn.setAttribute('aria-expanded', expand ? 'true' : 'false');
				menu.hidden = !expand;
			};

			btn.addEventListener('click', () => setExpanded(menu.hidden));

			const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
				setExpanded(e.matches);
				btn.hidden = e.matches;
			};
			const mq = window.matchMedia('(min-width: 50em)');
			handleViewports(mq);
			mq.addEventListener('change', handleViewports);
		}
	}
	customElements.define('menu-button', MenuButton);
</script>

<style>
	nav {
		z-index: 9999;
		position: relative;
		font-family: var(--font-brand);
		font-weight: 500;
		margin-bottom: 3.5rem;
	}

	/* ── Mobile header bar (always visible on mobile) ──────────── */
	.menu-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 1.25rem;
	}

	.site-title-mobile {
		font-size: var(--text-xl);
		font-weight: 700;
		color: var(--gray-0);
		text-decoration: none;
		letter-spacing: 0.05em;
	}

	/* ── Hamburger button ───────────────────────────────────────── */
	.menu-button {
		position: relative;
		display: flex;
		border: 0;
		border-radius: 999rem;
		padding: 0.5rem;
		font-size: 1.5rem;
		color: var(--gray-300);
		background: radial-gradient(var(--gray-900), var(--gray-800) 150%);
		box-shadow: var(--shadow-md);
		cursor: pointer;
	}

	.menu-button[aria-expanded='true'] {
		color: var(--gray-0);
		background:
			linear-gradient(180deg, var(--gray-600), transparent),
			radial-gradient(var(--gray-900), var(--gray-800) 150%);
	}

	.menu-button[hidden] { display: none; }

	.menu-button::before {
		position: absolute;
		inset: -1px;
		content: '';
		background: var(--gradient-stroke);
		border-radius: 999rem;
		z-index: -1;
	}

	/* ── Mobile dropdown panel ──────────────────────────────────── */
	.menu-content {
		position: absolute;
		left: 0;
		right: 0;
		background: var(--gray-999);
		border-bottom: 1px solid var(--gray-800);
		box-shadow: var(--shadow-lg);
		z-index: 100;
	}

	/* Full name hidden inside the mobile dropdown */
	.site-title-desktop { display: none; }

	.nav-items {
		margin: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-size: var(--text-md);
		line-height: 1.2;
		padding: 1.25rem 1.5rem;
	}

	.link {
		display: inline-block;
		padding: 0.4rem 0;
		color: var(--gray-300);
		text-decoration: none;
	}

	.link[aria-current='page'] { color: var(--gray-0); }

	.nav-end {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem 1.5rem 1.25rem;
		border-top: 1px solid var(--gray-800);
	}

	/* ── Desktop layout ─────────────────────────────────────────── */
	@media (min-width: 50em) {
		/* Hide the mobile bar entirely */
		.menu-header { display: none; }

		/*
			3-column grid. menu-header is gone.
			menu-content is display:contents → its 3 children fill the columns:
			  [nav-items] [site-title-desktop] [nav-end]
		*/
		nav {
			display: grid;
			grid-template-columns: 1fr auto 1fr;
			align-items: center;
			padding: 2.5rem 5rem;
			gap: 1rem;
		}

		.menu-content {
			display: contents;
			position: static;
			background: none;
			border: none;
			box-shadow: none;
		}

		/* Col 1: links pill, pinned left */
		.nav-items {
			justify-self: start;
			flex-direction: row;
			font-size: var(--text-sm);
			border-radius: 999rem;
			padding: 0.5rem 0.5625rem;
			gap: 0;
			background: radial-gradient(var(--gray-900), var(--gray-800) 150%);
			box-shadow: var(--shadow-md);
			position: relative;
		}

		.nav-items::before {
			position: absolute;
			inset: -1px;
			content: '';
			background: var(--gradient-stroke);
			border-radius: 999rem;
			z-index: -1;
		}

		.link {
			padding: 0.5rem 1rem;
			border-radius: 999rem;
			transition:
				color var(--theme-transition),
				background-color var(--theme-transition);
		}

		.link:hover,
		.link:focus {
			color: var(--gray-100);
			background-color: var(--accent-subtle-overlay);
		}

		.link[aria-current='page'] {
			color: var(--accent-text-over);
			background-color: var(--accent-regular);
		}

		/* Col 2: full name, centered */
		.site-title-desktop {
			display: flex;
			justify-self: center;
			font-size: var(--text-lg);
			font-weight: 600;
			color: var(--gray-0);
			text-decoration: none;
			white-space: nowrap;
		}

		/* Col 3: music + theme, pinned right */
		.nav-end {
			justify-self: end;
			padding: 0;
			border-top: none;
		}
	}

	@media (forced-colors: active) {
		.link[aria-current='page'] { color: SelectedItem; }
	}
</style>
