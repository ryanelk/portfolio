---
import type { ParsedProject } from '../utils/parseProject';

interface Props {
	project: ParsedProject;
}

const { data, id } = Astro.props.project;

const formattedDate = data.publishDate.getTime() > 0
	? data.publishDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
	: '';
---

<li class="project-tile" data-img={`${import.meta.env.BASE_URL}${data.img}`}>
	<h5>{formattedDate}</h5>
	{data.img
		? <a class="card" href={`work/${id}`} rel="noopener"><img decoding="async" src={`${import.meta.env.BASE_URL}/${data.img}`} alt={data.img_alt || ''} /></a>
		: <div class="card card--no-image"><span class="title">{data.title}</span></div>
	}
	<h4>{data.title}</h4>
	<p>{data.description}</p>
</li>

<script>
	import { getPrimaryColor } from '../pages/getDomColor';

	function loadImageColor(src: string): Promise<string | null> {
		return new Promise((resolve) => {
			const img = new Image();
			img.crossOrigin = 'anonymous';
			img.src = src;
			img.onload = () => {
				const canvas = document.createElement('canvas');
				const ctx = canvas.getContext('2d');
				if (!ctx) return resolve(null);
				canvas.width = img.naturalWidth;
				canvas.height = img.naturalHeight;
				ctx.drawImage(img, 0, 0);
				const { data } = ctx.getImageData(0, 0, canvas.width, canvas.height);
				resolve(getPrimaryColor(data));
			};
			img.onerror = () => resolve(null);
		});
	}

	document.querySelectorAll<HTMLElement>('.project-tile').forEach(async (tile) => {
		const src = tile.dataset.img;
		if (!src) return;
		const color = await loadImageColor(src);
		if (!color) return;
		const title = tile.querySelector<HTMLElement>('h4');
		if (title) title.style.color = color;
		const date = tile.querySelector<HTMLElement>('h5');
		if (date) date.style.color = color;
	});
</script>

<style>
	.project-tile {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.project-tile h4,
	.project-tile h5 {
		text-shadow:
			0 0 10px rgba(0, 0, 0, 0.3),
			0 0 10px rgba(255, 255, 255, 0.3);
	}

	.card {
		display: block;
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		transition: box-shadow 0.3s ease, transform 0.3s ease;
	}

	.card:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-6px) scale(1.02);
	}

	.card--no-image {
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		aspect-ratio: 16 / 9;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.title {
		padding: 0.5rem 1rem;
		background: var(--gray-999);
		color: var(--gray-200);
		border-radius: 0.375rem;
	}

	img {
		display: block;
		width: 100%;
		height: auto;
		transition: transform 0.3s ease;
	}

	.card:hover img {
		transform: scale(1.05);
	}

	@media (min-width: 50em) {
		.techtool.plist {
			display: flex;
			flex-wrap: wrap;
			gap: 4px;
			padding-top: 8px;
			list-style: none;
			padding-left: 0;
		}

		.techtool.plist li {
			display: inline-block;
			width: auto;
			padding: 0 8px;
			border-radius: 10px;
			font-size: 10px;
			line-height: 20px;
			color: #fff;
			background: #d9d9d9;
			border: none;
			font-weight: 700;
			list-style: none;
		}
	}
</style>
