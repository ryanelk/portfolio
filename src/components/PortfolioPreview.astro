---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
---
<li class="project-tile" data-img={`${import.meta.env.BASE_URL}/${data.img}`}>
  <h5>February 2024</h5>
    <a class="card" target="_blank" href={`work/${id}`} rel="noopener"><img decoding="async" src={`${import.meta.env.BASE_URL}/${data.img}`} alt={data.img_alt || ''}></a>
  <h4>Pixels</h4>
  <p>Experience a visual spectacle where photographs transform into pixelated particles, visualizing the deconstruction and reassembly of memories.</p>
  <ul class="techtool plist">
    <li>JavaScript</li>
    <li>WebGL</li>
    <li>Shader</li>
  </ul>
</li>

<script>
  import { getPrimaryColor } from '../pages/getDomColor';

  function loadImageColor(src: string): Promise<string | null> {
    return new Promise((resolve) => {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.src = src;
      img.onload = () => {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) return resolve(null);
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        ctx.drawImage(img, 0, 0);
        const { data } = ctx.getImageData(0, 0, canvas.width, canvas.height);
        resolve(getPrimaryColor(data));
      };
      img.onerror = () => resolve(null);
    });
  }

  document.querySelectorAll<HTMLElement>('.project-tile').forEach(async (tile) => {
    const src = tile.dataset.img;
    if (!src) return;
    const color = await loadImageColor(src);
    if (!color) return;
    const title = tile.querySelector<HTMLElement>('h4');
    if (title) title.style.color = color;
    const date = tile.querySelector<HTMLElement>('h5');
    if (date) date.style.color = color;
  });
</script>

