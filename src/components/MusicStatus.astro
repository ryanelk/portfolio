---
const BASE_URL = import.meta.env.BASE_URL;
---

<div class="nowPlayingCard" data-base-url={BASE_URL}>
  <div class="nowPlayingImage">
    <a id="songUrl" href="#">
      <img id="albumArt" alt="Album" src="" crossorigin="anonymous"/>
    </a>
  </div>

  <div id="nowPlayingDetails">
    <svg id="soundwave" class="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <rect class="bar bar1" x="2" y="11" width="2" height="2" rx="1"/>
      <rect class="bar bar2" x="6" y="11" width="2" height="2" rx="1"/>
      <rect class="bar bar3" x="10" y="11" width="2" height="2" rx="1"/>
      <rect class="bar bar4" x="14" y="11" width="2" height="2" rx="1"/>
      <rect class="bar bar5" x="18" y="11" width="2" height="2" rx="1"/>
    </svg>
  </div>
</div>

<script>
  import { getPrimaryColor } from '../pages/getDomColor';

  const card = document.querySelector(".nowPlayingCard") as HTMLElement;
  const BASE_URL = card.dataset.baseUrl || '';

  let prevSong = "" as string;
  let primaryColor = "" as string;

  async function fetchNowPlaying() {
    try {
      const res = await fetch(`${BASE_URL}/api/nowplaying`);
      const data = await res.json();

      if (!data.currTrack) {
        console.log('No track data available');
        return;
      }

      const albumArt = data.currTrack.image;
      const songUrl = data.currTrack.url;
      const isPlaying = data.currTrack.isPlaying;

      const songUrlId = document.getElementById('songUrl') as HTMLAnchorElement;
      const soundwave = document.getElementById('soundwave') as SVGElement;

      songUrlId.href = songUrl;

      // Toggle animation and appearance based on playing state
      const bars = soundwave.querySelectorAll('.bar');
      if (isPlaying) {
        soundwave.classList.add('playing');
        // Restore bar heights for animation
        (bars[0] as SVGRectElement).setAttribute('y', '8');
        (bars[0] as SVGRectElement).setAttribute('height', '8');
        (bars[1] as SVGRectElement).setAttribute('y', '4');
        (bars[1] as SVGRectElement).setAttribute('height', '16');
        (bars[2] as SVGRectElement).setAttribute('y', '6');
        (bars[2] as SVGRectElement).setAttribute('height', '12');
        (bars[3] as SVGRectElement).setAttribute('y', '2');
        (bars[3] as SVGRectElement).setAttribute('height', '20');
        (bars[4] as SVGRectElement).setAttribute('y', '7');
        (bars[4] as SVGRectElement).setAttribute('height', '10');
      } else {
        soundwave.classList.remove('playing');
        // Flatline all bars
        bars.forEach(bar => {
          (bar as SVGRectElement).setAttribute('y', '11');
          (bar as SVGRectElement).setAttribute('height', '2');
        });
      }

      // In future, only change color if image has changed. Make a boolean/flag for this
      if (prevSong !== songUrl) {
          primaryColor = await loadImage(albumArt);
          prevSong = songUrl;
          if (card) card.style.border = `2px solid ${primaryColor}`;

          // Update SVG colors
          bars.forEach(bar => (bar as SVGElement).style.fill = primaryColor);
      }

    } catch (err) {
      console.error(err);
    }
  }
  
  const loadImage = (img_url: string): Promise<string> => {
    return new Promise((resolve, reject) => {
      const albumArt = document.getElementById('albumArt') as HTMLImageElement;
      albumArt.crossOrigin = 'anonymous';
      albumArt.src = img_url;

      albumArt.onload = () => {
        albumArt.onload = null;

        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d') as CanvasRenderingContext2D;
        canvas.width = albumArt.width;
        canvas.height = albumArt.height;
        ctx.drawImage(albumArt, 0, 0);

        // [R, G, B, A ... ]
        const { data } = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const primaryColor = getPrimaryColor(data);

        albumArt.style.border = `2px solid ${primaryColor}`;
        // albumArt.style.col

        resolve(primaryColor);
      };

      albumArt.onerror = () => reject(new Error(`Failed to load image: ${img_url}`));
    });
  };
  

  fetchNowPlaying();
  setInterval(fetchNowPlaying, 5000);
</script>

<style>

.icon {
  width: 24px;
  height: 24px;
}

#soundwave .bar {
  fill: #c561f6;
}

/* When playing, animate the bars. Edit the first field to change speed of animation*/
#soundwave.playing .bar {
  animation: soundwave 0.60s ease-in-out infinite;
}

#soundwave.playing .bar1 {
  animation-delay: 0s;
}

#soundwave.playing .bar2 {
  animation-delay: 0.1s;
}

#soundwave.playing .bar3 {
  animation-delay: 0.2s;
}

#soundwave.playing .bar4 {
  animation-delay: 0.3s;
}

#soundwave.playing .bar5 {
  animation-delay: 0.4s;
}

@keyframes soundwave {
  0%, 100% {
    transform: scaleY(1);
    transform-origin: center;
  }
  50% {
    transform: scaleY(0.5);
    transform-origin: center;
  }
}

.nowPlayingCard {
    flex-shrink: 0;
    border-radius: 22px;
    border: 2px solid #c561f6;
    box-shadow: var(--shadow-md); /* to match the other header component */
    align-items: center;
    width: 160px;
    height: 56px;
    display: flex;
    justify-content: space-evenly;
    transition: all 0.5s ease;
    overflow: hidden;
}

    
  .nowPlayingCard a {
      color: #c561f6;
      text-decoration: none;
  }

  .nowPlayingCard a:hover {
      color: #c561f6;
      text-decoration: underline;
  }

  .nowPlayingImage {
    flex-shrink: 0;
  }

  .nowPlayingImage img {
      border-radius: 8px;
      border: 2px solid #491265;
      box-shadow: var(--shadow-md);
      transition: all 0.5s ease;
      width: 40px;
      height: 40px;
      margin: 10px;
      flex-shrink: 0;
      object-fit: cover;
      display: block;
  }


  .nowPlayingImage img:hover {
      opacity: 0.8;
  }

#nowPlayingDetails {
    justify-content: center;
    align-items: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
}

  .nowPlayingTitle, .playlistName {
      flex-shrink: 0;
      color: #000;
      white-space: nowrap;
      text-align: left;
      font-size: 20px;
      width: 100%;
  }

  .nowPlayingArtist, .playlistHeader {
      text-align: left;
      flex-shrink: 0;
      overflow: hidden;
      white-space: nowrap;
      width: 100%;
  }

  .nowPlayingTime {
      text-align: left;
  }

  .nowPlayingState {
      text-align: center;
      width: 20%;
      padding: 10px;
  }

  .nowPlayingState img{
      filter: invert(100%);
      width: 100%;
  }
</style>