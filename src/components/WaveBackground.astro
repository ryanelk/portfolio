<script>
  const WAVE_COLOR_INDICES = [1, 2, 3, 1, 2, 3, 1];
  const PROXIMITY_PX = 110;
  let waveScreenCenters: number[] = [];

  function updateWaveCenters() {
    const waves = document.querySelectorAll<HTMLElement>('.wave');
    waveScreenCenters = Array.from(waves).map(el => {
      const rect = el.getBoundingClientRect();
      return rect.top + rect.height / 2;
    });
  }

  function getWaveColor(waveIdx: number): string {
    const triplet = getComputedStyle(document.documentElement)
      .getPropertyValue(`--music-color-${WAVE_COLOR_INDICES[waveIdx]}`).trim() || '118, 17, 166';
    return `rgba(${triplet}, 0.78)`;
  }

  function spawnSplash(x: number, y: number, waveIdx: number) {
    const color = getWaveColor(waveIdx);
    const COUNT = 9;
    const container = document.createElement('div');
    container.style.cssText = `position:fixed;left:${x}px;top:${y}px;pointer-events:none;z-index:2;`;
    document.body.appendChild(container);

    for (let i = 0; i < COUNT; i++) {
      const angle = (i / COUNT) * 360;
      const dist = 28 + Math.random() * 24;
      const size = 6 + Math.random() * 6;
      const radians = (angle * Math.PI) / 180;
      const dx = Math.cos(radians) * dist;
      const dy = Math.sin(radians) * dist;
      const shape = i % 2 === 0
        ? 'polygon(50% 0%, 100% 100%, 0% 100%)'
        : 'polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)';
      const particle = document.createElement('div');
      particle.style.cssText = `position:absolute;width:${size}px;height:${size}px;background:${color};clip-path:${shape};left:${-size/2}px;top:${-size/2}px;transform-origin:center;`;
      container.appendChild(particle);
      particle.animate(
        [
          { transform: `translate(0,0) rotate(0deg) scale(1)`, opacity: 0.9 },
          { transform: `translate(${dx}px,${dy}px) rotate(${angle * 1.5}deg) scale(0)`, opacity: 0 },
        ],
        { duration: 480 + Math.random() * 120, easing: 'ease-out', fill: 'forwards' }
      );
    }
    setTimeout(() => container.remove(), 650);
  }

  let lastNearIdx = -1;
  document.addEventListener('mousemove', (e) => {
    const my = e.clientY;
    let nearestIdx = -1;
    let minDist = Infinity;
    for (let i = 0; i < waveScreenCenters.length; i++) {
      const d = Math.abs(my - waveScreenCenters[i]);
      if (d < minDist) { minDist = d; nearestIdx = i; }
    }
    const isNear = minDist < PROXIMITY_PX;
    if (!isNear && lastNearIdx !== -1) {
      spawnSplash(e.clientX, e.clientY, lastNearIdx);
      lastNearIdx = -1;
    } else if (isNear) {
      lastNearIdx = nearestIdx;
    }
  });

  updateWaveCenters();
  window.addEventListener('resize', updateWaveCenters);
</script>

<style>
  .wave-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .wave {
    position: absolute;
    /*
      width: 200%, left: -50% → center of element aligns with center of viewport.
      This ensures the diagonal sweeps evenly across both sides at all angles.
    */
    width: 200%;
    left: -50%;
    height: 330px;
    transform: rotate(-22deg);
    transform-origin: center center;
  }

  .wave path {
    transition: fill 1.5s ease-in-out;
  }

  /*
    At -22deg, a wave's left-viewport-edge top is at (top + ~278px).
    To cover y=0 (top-left corner), wave-1 must have top ≤ -278px ≈ -31vh.
    Spacing every 20vh fills the viewport to ~90vh with 7 bands.
  */
  .wave-1 { top: -35vh; }
  .wave-2 { top: -15vh; }
  .wave-3 { top:   5vh; }
  .wave-4 { top:  25vh; }
  .wave-5 { top:  45vh; }
  .wave-6 { top:  65vh; }
  .wave-7 { top:  85vh; }

  /* Fill colors */
  .wave-1 path { fill: rgba(var(--music-color-1, 118, 17, 166), 0.18); }
  .wave-2 path { fill: rgba(var(--music-color-2, 118, 17, 166), 0.14); }
  .wave-3 path { fill: rgba(var(--music-color-3, 118, 17, 166), 0.22); }
  .wave-4 path { fill: rgba(var(--music-color-1, 118, 17, 166), 0.17); }
  .wave-5 path { fill: rgba(var(--music-color-2, 118, 17, 166), 0.20); }
  .wave-6 path { fill: rgba(var(--music-color-3, 118, 17, 166), 0.15); }
  .wave-7 path { fill: rgba(var(--music-color-1, 118, 17, 166), 0.19); }

  /* Pure Y drift with staggered delays for rolling ebb */
  @keyframes drift-1 {
    0%, 100% { transform: rotate(-22deg) translateY(0px); }
    50%       { transform: rotate(-22deg) translateY(30px); }
  }
  @keyframes drift-2 {
    0%, 100% { transform: rotate(-22deg) translateY(20px); }
    50%       { transform: rotate(-22deg) translateY(-26px); }
  }
  @keyframes drift-3 {
    0%, 100% { transform: rotate(-22deg) translateY(-10px); }
    50%       { transform: rotate(-22deg) translateY(34px); }
  }
  @keyframes drift-4 {
    0%, 100% { transform: rotate(-22deg) translateY(14px); }
    50%       { transform: rotate(-22deg) translateY(-30px); }
  }
  @keyframes drift-5 {
    0%, 100% { transform: rotate(-22deg) translateY(-18px); }
    50%       { transform: rotate(-22deg) translateY(28px); }
  }
  @keyframes drift-6 {
    0%, 100% { transform: rotate(-22deg) translateY(22px); }
    50%       { transform: rotate(-22deg) translateY(-20px); }
  }
  @keyframes drift-7 {
    0%, 100% { transform: rotate(-22deg) translateY(6px); }
    50%       { transform: rotate(-22deg) translateY(32px); }
  }

  .wave-1 { animation: drift-1 18s ease-in-out infinite; animation-delay:  0s; }
  .wave-2 { animation: drift-2 21s ease-in-out infinite; animation-delay: -3s; }
  .wave-3 { animation: drift-3 16s ease-in-out infinite; animation-delay: -6s; }
  .wave-4 { animation: drift-4 24s ease-in-out infinite; animation-delay: -9s; }
  .wave-5 { animation: drift-5 19s ease-in-out infinite; animation-delay: -4s; }
  .wave-6 { animation: drift-6 22s ease-in-out infinite; animation-delay: -7s; }
  .wave-7 { animation: drift-7 17s ease-in-out infinite; animation-delay: -2s; }

  @media (prefers-reduced-motion: reduce) {
    .wave { animation: none; }
  }
</style>
